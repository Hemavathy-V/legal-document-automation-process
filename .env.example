#
# Copy this file to .env and fill in your own values.
# The .env file is git-ignored and should never be committed.
#

# ---------------------------------------------------------------------------
# Database connection
# ---------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_database_password_here
DATABASE_NAME=contract_management1

# ---------------------------------------------------------------------------
# Security — generate a long random string for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
SECRET_KEY=change_this_to_a_long_random_secret_key_in_production
